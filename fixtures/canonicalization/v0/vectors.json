        "origin": "http://[2001:db8::1]",
        "path": "/a",
        "query_present": false,
        "query_raw": null,
        "query_canonical": null,
        "query_pairs": [],
        "fragment_present": false,
        "fragment_raw": null,
        "canonical_route_url": "http://[2001:db8::1]/a",
        "canonical_observation_url": "http://[2001:db8::1]/a",
        "warnings": []
      }
    },
    {
      "id": "gau-extensionless-path-retained",
      "input": "https://finance.fixture.test/",

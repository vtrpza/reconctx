    },
    {
      "id": "relative-rejected",
      "input": "/relative",
      "error": "absolute HTTP(S) URL required"
    },
    {
      "id": "userinfo-rejected",
      "input": "https://user:pass@example.com/",
      "error": "userinfo forbidden"
    },
    {
      "id": "invalid-percent-rejected",
      "input": "https://example.com/%ZZ",
      "error": "invalid percent escape"
    },
    {
      "id": "unsupported-scheme-rejected",
      "input": "ftp://example.com/file",
      "error": "unsupported scheme"
    },
    {
      "id": "invalid-port-rejected",
      "input": "https://example.com:99999/",
      "error": "port out of range"
    },
    {
      "id": "backslash-rejected",
      "input": "https://example.com\\path",
      "error": "ambiguous slash"
    },
    {
      "id": "control-character-rejected",
      "input": "https://example.com/\u0001",
      "error": "control character"
    },
    {
      "id": "missing-host-rejected",
      "input": "https:///path",
      "error": "authority required"
    },
    {
      "id": "invalid-idna-rejected",
      "input": "https://-bad.example/",
      "error": "invalid IDNA host"
    },
    {
      "id": "short-numeric-ip-rejected",
      "input": "http://127.1/",
      "error": "non-standard numeric IP"
    },
    {
      "id": "integer-ip-rejected",
      "input": "http://2130706433/",
      "error": "non-standard numeric IP"
    },
    {
      "id": "octal-ip-rejected",
      "input": "http://0177.0.0.1/",
      "error": "non-standard numeric IP"
    },
    {
      "id": "hex-ip-rejected",
      "input": "http://0x7f000001/",
      "error": "non-standard numeric IP"
    },
    {
      "id": "malformed-fragment-percent-rejected",
      "input": "https://example.com/#%ZZ",
      "error": "invalid percent escape"
    },
    {
      "id": "bracketed-reg-name-rejected",
      "input": "http://[example.test]/",
      "error": "bracketed authority requires IPv6"
    },
    {
      "id": "bracketed-ipv4-rejected",
      "input": "http://[127.0.0.1]/",
      "error": "bracketed authority requires IPv6"
    },
    {
      "id": "mapped-ideographic-numeric-ip-rejected",

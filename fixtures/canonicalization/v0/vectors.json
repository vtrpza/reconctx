{
  "policy_version": "url-canonicalization/v0",
  "source_basis": [
    "RFC 3986",
    "GAU 2.2.4 fixtures",
    "Katana v1.6.1 fixtures",
    "Arjun 2.2.7 fixtures"
  ],
  "url_cases": [
    {
      "id": "lowercase-default-port-fragment-query-lossless",
      "input": "HTTP://Example.COM:80?b=2&a=1&a&empty=#section",
      "expected": {
        "raw_url": "HTTP://Example.COM:80?b=2&a=1&a&empty=#section",
        "scheme": "http",
        "host": "example.com",
        "port": null,
        "origin": "http://example.com",
        "path": "/",
        "query_present": true,
        "query_raw": "b=2&a=1&a&empty=",
        "query_canonical": "b=2&a=1&a&empty=",
        "query_pairs": [
          {
            "index": 0,
            "raw_name": "b",
            "raw_value": "2",
            "name": "b",
            "value": "2",
            "has_equals": true
          },
          {
            "index": 1,
            "raw_name": "a",
            "raw_value": "1",
            "name": "a",
            "value": "1",
            "has_equals": true
          },
          {
            "index": 2,
            "raw_name": "a",
            "raw_value": null,
            "name": "a",
            "value": null,
            "has_equals": false
          },
          {
            "index": 3,
            "raw_name": "empty",
            "raw_value": "",
            "name": "empty",
            "value": "",
            "has_equals": true
          }
        ],
        "fragment_present": true,
        "fragment_raw": "section",
        "canonical_route_url": "http://example.com/",
        "canonical_observation_url": "http://example.com/?b=2&a=1&a&empty=",
        "warnings": [
          "fragment_removed"
        ]
      }
    },
    {
      "id": "dot-segments-and-percent-encoding",
      "input": "https://EXAMPLE.com/a/./b/../%7euser/%2f?q=%7e+x%2f",
      "expected": {
        "raw_url": "https://EXAMPLE.com/a/./b/../%7euser/%2f?q=%7e+x%2f",
        "scheme": "https",
        "host": "example.com",
        "port": null,
        "origin": "https://example.com",
        "path": "/a/~user/%2F",
        "query_present": true,
        "query_raw": "q=%7e+x%2f",
        "query_canonical": "q=~+x%2F",
        "query_pairs": [
          {
            "index": 0,
            "raw_name": "q",
            "raw_value": "%7e+x%2f",
            "name": "q",
            "value": "~+x%2F",
            "has_equals": true
          }
        ],
        "fragment_present": false,
        "fragment_raw": null,
        "canonical_route_url": "https://example.com/a/~user/%2F",
        "canonical_observation_url": "https://example.com/a/~user/%2F?q=~+x%2F",
        "warnings": []
      }
    },
    {
      "id": "path-case-repeated-and-trailing-slash-preserved",
      "input": "https://example.com/A//b/",
      "expected": {
        "raw_url": "https://example.com/A//b/",
        "scheme": "https",
        "host": "example.com",
        "port": null,
        "origin": "https://example.com",
        "path": "/A//b/",
        "query_present": false,
        "query_raw": null,
        "query_canonical": null,
        "query_pairs": [],
        "fragment_present": false,
        "fragment_raw": null,
        "canonical_route_url": "https://example.com/A//b/",
        "canonical_observation_url": "https://example.com/A//b/",
        "warnings": []
      }
    },
    {
      "id": "https-default-port-removed",
      "input": "https://example.com:443/login",
      "expected": {
        "raw_url": "https://example.com:443/login",
        "scheme": "https",
        "host": "example.com",
        "port": null,
        "origin": "https://example.com",
        "path": "/login",
        "query_present": false,
        "query_raw": null,
        "query_canonical": null,
        "query_pairs": [],
        "fragment_present": false,
        "fragment_raw": null,
        "canonical_route_url": "https://example.com/login",
        "canonical_observation_url": "https://example.com/login",
        "warnings": []
      }
    },
    {
      "id": "non-default-port-preserved",
      "input": "http://127.0.0.1:18080/api/search?q=fixture",
      "expected": {
        "raw_url": "http://127.0.0.1:18080/api/search?q=fixture",
        "scheme": "http",
        "host": "127.0.0.1",
        "port": 18080,
        "origin": "http://127.0.0.1:18080",
        "path": "/api/search",
        "query_present": true,
        "query_raw": "q=fixture",
        "query_canonical": "q=fixture",
        "query_pairs": [
          {
            "index": 0,
            "raw_name": "q",
            "raw_value": "fixture",
            "name": "q",
            "value": "fixture",
            "has_equals": true
          }
        ],
        "fragment_present": false,
        "fragment_raw": null,
        "canonical_route_url": "http://127.0.0.1:18080/api/search",
        "canonical_observation_url": "http://127.0.0.1:18080/api/search?q=fixture",
        "warnings": []
      }
    },
    {
      "id": "query-order-preserved",
      "input": "https://example.com/users?sort=asc&id=2&id=1",
      "expected": {
        "raw_url": "https://example.com/users?sort=asc&id=2&id=1",
        "scheme": "https",
        "host": "example.com",
        "port": null,
        "origin": "https://example.com",
        "path": "/users",
        "query_present": true,
        "query_raw": "sort=asc&id=2&id=1",
        "query_canonical": "sort=asc&id=2&id=1",
        "query_pairs": [
          {
            "index": 0,
            "raw_name": "sort",
            "raw_value": "asc",
            "name": "sort",
            "value": "asc",
            "has_equals": true
          },
          {
            "index": 1,
            "raw_name": "id",
            "raw_value": "2",
            "name": "id",
            "value": "2",
            "has_equals": true
          },
          {
            "index": 2,
            "raw_name": "id",
            "raw_value": "1",
            "name": "id",
            "value": "1",
            "has_equals": true
          }
        ],
        "fragment_present": false,
        "fragment_raw": null,
        "canonical_route_url": "https://example.com/users",
        "canonical_observation_url": "https://example.com/users?sort=asc&id=2&id=1",
        "warnings": []
      }
    },
    {
      "id": "empty-query-distinct-in-observation",
      "input": "https://example.com/path?",
      "expected": {
        "raw_url": "https://example.com/path?",

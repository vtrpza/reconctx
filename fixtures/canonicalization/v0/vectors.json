        "host": "example.com",
        "port": null,
        "origin": "https://example.com",
        "path": "/path",
        "query_present": true,
        "query_raw": "",
        "query_canonical": "",
        "query_pairs": [],
        "fragment_present": false,
        "fragment_raw": null,
        "canonical_route_url": "https://example.com/path",
        "canonical_observation_url": "https://example.com/path?",
        "warnings": []
      }
    },
    {
      "id": "idna-and-utf8-path",
      "input": "https://BÜCHER.example/é",
      "expected": {
        "raw_url": "https://BÜCHER.example/é",
        "scheme": "https",
        "host": "xn--bcher-kva.example",
        "port": null,
        "origin": "https://xn--bcher-kva.example",
        "path": "/%C3%A9",
        "query_present": false,
        "query_raw": null,
        "query_canonical": null,
        "query_pairs": [],
        "fragment_present": false,
